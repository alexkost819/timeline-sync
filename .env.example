# Home Assistant
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token_here
# Any HA entity whose state changes represent location: device_tracker.*, sensor.*_geocoded_location, etc.
HA_ENTITY=device_tracker.my_phone

# Google APIs
# Path to OAuth2 credentials JSON downloaded from Google Cloud Console
GOOGLE_CREDENTIALS_FILE=credentials.json
# Name of the Google Calendar to create/use (created if it doesn't exist)
GOOGLE_CALENDAR_NAME=Timeline
# Google Places API key (optional — skips place enrichment if unset)
PLACES_API_KEY=
# Max Places API calls per day (well within $200/month free credit at ~$0.032/call)
PLACES_DAILY_LIMIT=50

# Google Contacts (People API) — used to label locations with contact names
# How often to re-fetch contacts from Google (hours)
CONTACTS_REFRESH_HOURS=24
# Local cache of contacts (written after each fetch for fast restarts)
CONTACTS_CACHE_FILE=contacts_cache.json

# Sync behavior
SYNC_WINDOW_HOURS=48
# Minimum visit duration in minutes; shorter visits (and not-yet-long-enough ongoing visits) are ignored
MIN_VISIT_MINUTES=10
